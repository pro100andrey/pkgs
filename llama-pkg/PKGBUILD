# Maintainer: pro100Andrey
pkgname=llama-cpp-git
pkgver=r8952.983ca899
pkgrel=1
pkgdesc="LLM inference in C/C++ (Optimized for Zen4 + Vulkan)"
arch=('x86_64')
url="https://github.com/ggml-org/llama.cpp"
license=('MIT')
depends=('vulkan-icd-loader' 'gcc-libs' 'glibc')
makedepends=('git' 'cmake' 'ninja' 'vulkan-headers')
provides=('llama-cpp')
conflicts=('llama-cpp')
source=('git+https://github.com/ggml-org/llama.cpp.git')
sha256sums=('SKIP')

pkgver() {
  cd llama.cpp
  printf "r%s.%s" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

build() {
  cmake -B build -S llama.cpp -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DGGML_VULKAN=ON \
    -DGGML_VULKAN_ASYNC_COMPUTE=ON \
    -DGGML_AVX512=ON \
    -DGGML_AVX512_VBMI=ON \
    -DGGML_AVX512_VNNI=ON \
    -DGGML_AVX512_BF16=ON \
    -DGGML_LTO=ON \
    -DCMAKE_C_FLAGS="-march=znver4 -O3" \
    -DCMAKE_CXX_FLAGS="-march=znver4 -O3"
    
  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 llama.cpp/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}