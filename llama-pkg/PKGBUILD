# Maintainer: pro100Andrey
pkgname=llama-cpp
pkgver=9048
pkgrel=1
pkgdesc="LLM inference in C/C++ (Optimized for Zen4 + Vulkan)"
arch=('x86_64')
url="https://github.com/ggml-org/llama.cpp"
license=('MIT')
depends=('vulkan-icd-loader' 'gcc-libs' 'glibc')
makedepends=('cmake' 'ninja' 'vulkan-headers')
conflicts=('llama-cpp-git')
options=('!debug' 'strip')
source=("llama.cpp-${pkgver}.tar.gz::https://github.com/ggml-org/llama.cpp/archive/refs/tags/b${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cmake -B build -S "llama.cpp-b${pkgver}" -G Ninja \
    --log-level=WARNING \
    -DLLAMA_BUILD_TESTS=OFF \
    -DLLAMA_BUILD_EXAMPLES=OFF \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DGGML_VULKAN=ON \
    -DGGML_AVX512=ON \
    -DGGML_AVX512_VBMI=ON \
    -DGGML_AVX512_VNNI=ON \
    -DGGML_AVX512_BF16=ON \
    -DGGML_LTO=ON \
    -DCMAKE_C_FLAGS="-march=native -O3 -O3 -pipe -fno-plt -ffile-prefix-map=$srcdir=." \
    -DCMAKE_CXX_FLAGS="-march=native -O3 -O3 -pipe -fno-plt -ffile-prefix-map=$srcdir=."

  cmake --build build -j"$(nproc)"
}

package() {
  DESTDIR="$pkgdir" cmake --install build
  install -Dm644 "llama.cpp-b${pkgver}/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}