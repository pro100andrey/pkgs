#!/bin/bash

# Shared helper functions for package scripts in this repository.
#
# Provided capabilities:
# - Compare installed package version with PKGBUILD target version.
# - Run makepkg only when installation is needed.
# - Optional destructive git cleanup with explicit confirmation.
# - Dispatch common update commands: current/latest/set/status.

pkgbuild_target_version() {
    local pkgbuild="$1"
    local pkgver
    local pkgrel

    pkgver="$(grep -o '^pkgver=\S*' "$pkgbuild" | sed 's/^pkgver=//')"
    pkgrel="$(grep -o '^pkgrel=\S*' "$pkgbuild" | sed 's/^pkgrel=//')"

    printf '%s-%s\n' "$pkgver" "$pkgrel"
}

is_package_install_needed() {
    local package_name="$1"
    local pkgbuild="$2"
    local installed_version

    if ! installed_version="$(pacman -Q "$package_name" 2>/dev/null | awk '{print $2}')"; then
        return 0
    fi

    [[ "$installed_version" != "$(pkgbuild_target_version "$pkgbuild")" ]]
}

install_pkg_if_needed() {
    local package_name="$1"
    local pkgbuild="$2"
    shift 2

    if ! is_package_install_needed "$package_name" "$pkgbuild"; then
        echo "$package_name $(pkgbuild_target_version "$pkgbuild") is already installed; skipping makepkg"
        return 0
    fi

    makepkg "$@"
}

git_has_local_changes() {
    [[ -n "$(git status --porcelain --untracked-files=all 2>/dev/null)" ]]
}

reset_git() {
    if git_has_local_changes; then
        echo "Warning: Local git changes detected. Resetting git will discard tracked and untracked files:"
        git status --short --untracked-files=all
        read -rp "Do you want to continue? [y/N] " response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            echo "Aborting."
            exit 1
        fi
    fi

    git reset --hard
    git clean -fd
}

# Shared command dispatcher for package update scripts.
# Requires functions in caller script:
# - get_current
# - get_latest
# - set_pkgver
run_update_command() {
    case "${1:-status}" in
    current)
        get_current
        ;;
    latest)
        get_latest
        ;;
    set)
        [[ -n "${2:-}" ]] || {
            echo "Missing version"
            exit 1
        }
        set_pkgver "$2"
        ;;
    status)
        local current latest
        current="$(get_current)"
        latest="$(get_latest 2>/dev/null || echo error)"
        echo "current=$current latest=$latest"
        ;;
    *)
        echo "Usage: $0 {current|latest|set <ver>|status}"
        exit 1
        ;;
    esac
}
