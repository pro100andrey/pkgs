#!/bin/bash

# Shared helper functions for package scripts in this repository.
#
# Provided capabilities:
# - Compare installed package version with PKGBUILD target version.
# - Run makepkg only when installation is needed.
# - Optional destructive git cleanup with explicit confirmation.
# - Dispatch common update commands: current/latest/set/status.

pkgbuild_target_version() {
    local pkgbuild="$1"
    local pkgver
    local pkgrel

    pkgver="$(grep -o '^pkgver=\S*' "$pkgbuild" | sed 's/^pkgver=//')"
    pkgrel="$(grep -o '^pkgrel=\S*' "$pkgbuild" | sed 's/^pkgrel=//')"

    printf '%s-%s\n' "$pkgver" "$pkgrel"
}

is_package_install_needed() {
    local package_name="$1"
    local pkgbuild="$2"
    local installed_version

    if ! installed_version="$(pacman -Q "$package_name" 2>/dev/null | awk '{print $2}')"; then
        return 0
    fi

    [[ "$installed_version" != "$(pkgbuild_target_version "$pkgbuild")" ]]
}

install_pkg_if_needed() {
    local package_name="$1"
    local pkgbuild="$2"
    local pkg_dir
    shift 2

    pkg_dir="$(cd "$(dirname "$pkgbuild")" && pwd)"

    if ! is_package_install_needed "$package_name" "$pkgbuild"; then
        echo "$package_name $(pkgbuild_target_version "$pkgbuild") is already installed; skipping makepkg"
        return 0
    fi

    (
        cd "$pkg_dir"
        makepkg "$@"
    )
}

git_has_local_changes() {
    [[ -n "$(git status --porcelain --untracked-files=all 2>/dev/null)" ]]
}

reset_git() {
    if git_has_local_changes; then
        echo "Warning: Local git changes detected. Resetting git will discard tracked and untracked files:"
        git status --short --untracked-files=all
        read -rp "Do you want to continue? [y/N] " response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            echo "Aborting."
            exit 1
        fi
    fi

    git reset --hard
    git clean -fd
}

# Get current pkgver from PKGBUILD.
# Requires global variable: PKGBUILD
get_current() {
    grep -o '^pkgver=\S*' "$PKGBUILD" 2>/dev/null | sed 's/^pkgver=//' || true
}

# Initialize package environment variables.
# Sets: PACKAGE_NAME, PKG_DIR, PKGBUILD
# Parameters:
#   $1 - Package name (e.g., "llama-cpp")
#   $2 - Package directory name (e.g., "llama-pkg")
init_package_env() {
    local package_name="$1"
    local pkg_dir_name="$2"
    PACKAGE_NAME="$package_name"
    PKG_DIR="$(cd "$(dirname "${BASH_SOURCE[1]}")/../../$pkg_dir_name" && pwd)"
    PKGBUILD="$PKG_DIR/PKGBUILD"
}

# Generic set_pkgver function for update scripts.
# Requires global variables: PKGBUILD, PKG_DISPLAY_NAME
# Resets pkgrel to 1 when pkgver changes, increments when unchanged.
set_pkgver() {
    local ver="$1"
    local old_ver
    local old_rel
    old_ver="$(get_current)"
    old_rel="$(grep -o '^pkgrel=\S*' "$PKGBUILD" 2>/dev/null | sed 's/^pkgrel=//' || echo 1)"

    sed -i "s/^pkgver=.*/pkgver=${ver}/" "$PKGBUILD"

    if [[ "$old_ver" != "$ver" ]]; then
        sed -i "s/^pkgrel=.*/pkgrel=1/" "$PKGBUILD"
        echo "==> $PKG_DISPLAY_NAME: pkgver updated to ${ver}, pkgrel reset to 1 in $PKGBUILD"
    else
        local new_rel=$((old_rel + 1))
        sed -i "s/^pkgrel=.*/pkgrel=${new_rel}/" "$PKGBUILD"
        echo "==> $PKG_DISPLAY_NAME: pkgver unchanged (${ver}), pkgrel incremented to ${new_rel} in $PKGBUILD"
    fi
}

# Shared command dispatcher for package update scripts.
# Requires global variables: PKGBUILD, PKG_DISPLAY_NAME
# Requires functions in caller script:
# - get_latest
run_update_command() {
    case "${1:-status}" in
    current)
        get_current
        ;;
    latest)
        get_latest
        ;;
    set)
        [[ -n "${2:-}" ]] || {
            echo "Missing version"
            exit 1
        }
        set_pkgver "$2"
        ;;
    status)
        local current latest
        current="$(get_current)"
        latest="$(get_latest 2>/dev/null || echo error)"
        echo "current=$current latest=$latest"
        ;;
    *)
        echo "Usage: $0 {current|latest|set <ver>|status}"
        exit 1
        ;;
    esac
}
