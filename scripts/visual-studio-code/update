#!/bin/bash
set -euo pipefail

# Update helper for visual-studio-code PKGBUILD version fields.
#
# Commands are provided by run_update_command from scripts/common:
# current | latest | set <version> | status

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../common
source "$SCRIPT_DIR/../common"

init_package_env "visual-studio-code" "visual-studio-code"
PKG_DISPLAY_NAME="visual-studio-code"

get_latest() {
    local ver
    ver="$(curl -sfL https://update.code.visualstudio.com/api/releases/stable |
        grep -o '"[0-9][0-9.]*"' |
        head -n1 |
        tr -d '"')"

    [[ -n "$ver" ]] && echo "$ver" || return 1
}

run_update_command "$@"
