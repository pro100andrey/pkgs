#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/../common"

PACKAGE_NAME="visual-studio-code"
PKG_DIR="$(cd "${SCRIPT_DIR}/../../visual-studio-code" && pwd)"
PKGBUILD="${PKG_DIR}/PKGBUILD"

function install() {
    install_pkg_if_needed "$PACKAGE_NAME" "$PKGBUILD" -sic
}

function reset_git {
    if ! git diff --quiet || ! git diff --cached --quiet; then
        echo "Warning: Uncommitted changes detected. Resetting git will discard these changes."
        read -rp "Do you want to continue? [y/N] " response
        if [[ ! "$response" =~ ^[Yy]$ ]]; then
            echo "Aborting."
            exit 1
        fi
    fi

    git reset --hard
    git clean -fd
}

function main {
    install
    reset_git
}

main "$@"
