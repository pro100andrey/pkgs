#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PKG_DIR="$(cd "${SCRIPT_DIR}/../../visual-studio-code" && pwd)"
PKGBUILD="${PKG_DIR}/PKGBUILD"

function target_version() {
    local pkgver
    local pkgrel

    pkgver="$(grep -o '^pkgver=\S*' "$PKGBUILD" | sed 's/^pkgver=//')"
    pkgrel="$(grep -o '^pkgrel=\S*' "$PKGBUILD" | sed 's/^pkgrel=//')"

    printf '%s-%s\n' "$pkgver" "$pkgrel"
}

function is_install_needed() {
    local installed_version

    if ! installed_version="$(pacman -Q visual-studio-code 2>/dev/null | awk '{print $2}')"; then
        return 0
    fi

    [[ "$installed_version" != "$(target_version)" ]]
}

function install() {
    if ! is_install_needed; then
        echo "visual-studio-code $(target_version) is already installed; skipping makepkg"
    else
        makepkg -sic
    fi

}

function reset_git {
    git reset --hard
    git clean -fd
}

function main {
    install
}

main "$@"
