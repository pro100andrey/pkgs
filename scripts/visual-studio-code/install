#!/bin/bash
set -euo pipefail

# Build/install helper for the visual-studio-code package recipe.
#
# Behavior:
# - Installs only when installed package version differs from PKGBUILD target.
# - Optional repo cleanup is available via 'cleanup' or 'reset' argument.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../common
source "${SCRIPT_DIR}/../common"

init_package_env "visual-studio-code" "visual-studio-code"

function install() {
    install_pkg_if_needed "$PACKAGE_NAME" "$PKGBUILD" -sic
}

function main {
    install

    reset_git
}

main "$@"
