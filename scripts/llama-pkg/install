#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../common
source "${SCRIPT_DIR}/../common"

PACKAGE_NAME="llama-cpp"
PKG_DIR="$(cd "${SCRIPT_DIR}/../../llama-pkg" && pwd)"
PKGBUILD="${PKG_DIR}/PKGBUILD"

function prepare_dirs {
    mkdir -p "$HOME/.llama.cpp/models"
}

function install_models_ini {
    local source_models_ini="${SCRIPT_DIR}/configs/models.ini"
    local target_models_ini="$HOME/.llama.cpp/models.ini"
    local full_models_path="$HOME/.llama.cpp/models"

    # Create or update the models.ini file
    cp -u "$source_models_ini" "$target_models_ini"

    # Replace the placeholder with the actual path
    sed -i "s|TARGET_PATH|$full_models_path|g" "$target_models_ini"

    echo "Config file '$target_models_ini' patched with absolute paths."
}

function install_pkg() {
    install_pkg_if_needed "$PACKAGE_NAME" "$PKGBUILD" -sic
}

function reset_git {
    git reset --hard
    git clean -fd
}

function main {

    prepare_dirs

    if [[ "${1:-}" == "config" ]]; then
        install_models_ini
    else
        install_pkg
        install_models_ini
    fi

    reset_git
}

main "$@"
