#!/bin/bash
set -euo pipefail

# Build/install helper for the llama-cpp package recipe.
#
# Behavior:
# - Installs only when installed package version differs from PKGBUILD target.
# - Copies/patches models.ini into ~/.llama.cpp/models.ini.
# - 'config' mode updates models.ini only.
# - Performs repository cleanup via reset_git after execution.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../common
source "${SCRIPT_DIR}/../common"

init_package_env "llama-cpp" "llama-pkg"

function prepare_dirs {
    mkdir -p "$HOME/.llama.cpp/models"
}

function install_models_ini {
    local source_models_ini="${PKG_DIR}/configs/models.ini"
    local target_models_ini="$HOME/.llama.cpp/models.ini"
    local full_models_path="$HOME/.llama.cpp/models"

    # Create or update the models.ini file
    cp -u "$source_models_ini" "$target_models_ini"

    # Replace the placeholder with the actual path
    sed -i "s|TARGET_PATH|$full_models_path|g" "$target_models_ini"

    echo "Config file '$target_models_ini' patched with absolute paths."
}

function install_pkg() {
    install_pkg_if_needed "$PACKAGE_NAME" "$PKGBUILD" -sic
}

function main {

    prepare_dirs

    if [[ "${1:-}" == "config" ]]; then
        install_models_ini
    else
        install_pkg
        install_models_ini
    fi

    reset_git
}

main "$@"
