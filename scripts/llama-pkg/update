#!/bin/bash
set -euo pipefail

# Update helper for llama-cpp PKGBUILD version fields.
#
# Commands are provided by run_update_command from scripts/common:
# current | latest | set <version> | status

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../common
source "$SCRIPT_DIR/../common"

init_package_env "llama-cpp" "llama-pkg"
PKG_DISPLAY_NAME="llama-pkg"

get_latest() {
    local tag
    tag="$(curl -sfL -H "User-Agent: pkgs-update-script" "https://api.github.com/repos/ggml-org/llama.cpp/releases/latest" |
        grep '"tag_name"' |
        sed -E 's/.*"tag_name"\s*:\s*"b?([0-9]+)".*/\1/' |
        head -n1)"

    [[ -n "$tag" ]] && echo "$tag" || return 1
}

run_update_command "$@"
