#!/bin/bash

get_github_ver() {
    local owner=$1
    local repo=$2
    local ua="User-Agent: Arch-Check-Script"

    # Get default branch (follow redirects with -L)
    local branch
    branch=$(curl -sfL -H "$ua" "https://api.github.com/repos/$owner/$repo" \
        | jq -r '.default_branch // "master"')
    [[ -z "$branch" || "$branch" == "null" ]] && branch="master"

    # Get latest commit SHA (fix: jq .sha[:8] doesn't work — use cut instead)
    local hash
    hash=$(curl -sfL -H "$ua" "https://api.github.com/repos/$owner/$repo/commits/$branch" \
        | jq -r '.sha // empty' | cut -c1-8)
    [[ -z "$hash" ]] && { echo "error"; return 1; }

    # Get commit count via Link header pagination trick
    # Fix: HTTP headers have \r\n — strip \r before grepping
    local link
    link=$(curl -sfLI -H "$ua" \
        "https://api.github.com/repos/$owner/$repo/commits?per_page=1&sha=$branch" \
        | tr -d '\r')
    local revcount
    revcount=$(echo "$link" | grep -i '^link:' | grep -oP '\bpage=\K\d+(?=>; rel="last")')

    [[ -z "$revcount" ]] && { echo "r?.${hash}"; return; }
    echo "r${revcount}.${hash}"
}

# Format: "owner/repo:path/to/PKGBUILD"
REPOS=(
    "ggerganov/llama.cpp:llama-pkg/PKGBUILD"
)

# Collect status for all repos
declare -a OUTDATED_REPOS
declare -a OUTDATED_PKGBUILDS
declare -a OUTDATED_CURRENT
declare -a OUTDATED_LATEST

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

printf "%-25s  %-22s  %s\n" "Repository" "Installed" "Latest"
printf '%0.s-' {1..65}; echo

idx=0
for entry in "${REPOS[@]}"; do
    IFS=':' read -r repo_path pkgbuild <<< "$entry"
    IFS='/' read -r owner repo <<< "$repo_path"

    pkgbuild_abs="$SCRIPT_DIR/$pkgbuild"
    current=$(grep -oP '^pkgver=\K\S+' "$pkgbuild_abs" 2>/dev/null || echo "unknown")
    latest=$(get_github_ver "$owner" "$repo")

    if [[ "$latest" == "error" || "$latest" == r?.* ]]; then
        printf "%-25s  %-22s  (fetch error)\n" "$repo" "$current"
    elif [[ "$current" == "$latest" ]]; then
        printf "%-25s  %-22s  (up-to-date)\n" "$repo" "$current"
    else
        idx=$((idx + 1))
        printf "[%d] %-22s  %-22s  -> %s (update available)\n" "$idx" "$repo" "$current" "$latest"
        OUTDATED_REPOS+=("$repo")
        OUTDATED_PKGBUILDS+=("$pkgbuild_abs")
        OUTDATED_CURRENT+=("$current")
        OUTDATED_LATEST+=("$latest")
    fi
done

# --upgrade mode: ask user which packages to build
if [[ "$1" == "upgrade" ]]; then
    if [[ ${#OUTDATED_REPOS[@]} -eq 0 ]]; then
        echo -e "\nAll packages are up-to-date."
        exit 0
    fi

    echo
    echo -n "Which packages do you want to upgrade? (e.g. 1 2 3, or 'all', or Enter to skip): "
    read -r selection

    [[ -z "$selection" ]] && exit 0

    declare -a TO_BUILD
    if [[ "$selection" == "all" ]]; then
        for i in "${!OUTDATED_REPOS[@]}"; do
            TO_BUILD+=("$i")
        done
    else
        for num in $selection; do
            if [[ "$num" =~ ^[0-9]+$ ]] && (( num >= 1 && num <= ${#OUTDATED_REPOS[@]} )); then
                TO_BUILD+=($((num - 1)))
            else
                echo "Skipping invalid selection: $num"
            fi
        done
    fi

    for i in "${TO_BUILD[@]}"; do
        repo="${OUTDATED_REPOS[$i]}"
        pkgbuild_abs="${OUTDATED_PKGBUILDS[$i]}"
        new_ver="${OUTDATED_LATEST[$i]}"

        if [[ "$new_ver" == "error" || "$new_ver" == r?.* ]]; then
            echo "==> $repo: skipping — invalid version '${new_ver}'"
            continue
        fi
        sed -i "s/^pkgver=.*/pkgver=${new_ver}/" "$pkgbuild_abs"
        echo "==> $repo: pkgver updated to ${new_ver} in $pkgbuild_abs"
    done
fi